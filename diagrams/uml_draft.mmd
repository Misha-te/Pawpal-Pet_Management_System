classDiagram

    class Task {
        +str description
        +int duration_minutes
        +str priority
        +str frequency
        +str due_time
        +bool completed
        +str pet_name
        +priority_score() int
        +mark_complete() None
    }


    class PetInfo {
        +str name
        +str species
        +int age
        +list~Task~ tasks
        +add_task(task: Task) None
        +list_tasks() list~Task~
        +pending_tasks() list~Task~
    }


    class UserInfo {
        +str name
        +int available_minutes
        +dict preferences
        +list~PetInfo~ pets
        +add_pet(pet: PetInfo) None
        +list_pets() list~PetInfo~
        +all_tasks() list~Task~
    }


    class Schedule {
        +UserInfo owner
        +list~Task~ plan
        +generate() list~Task~
        +explain() str
        -_pending_tasks() list~Task~
        -_is_preferred(task: Task) bool
    }


    UserInfo "1" --> "*" PetInfo : owns
    PetInfo "1" o-- "*" Task : has
    Schedule "1" --> "1" UserInfo : plans for
    Schedule ..> Task : organizes across pets
